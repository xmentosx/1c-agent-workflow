&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Успешно = Ложь;
	ПутьПараметров = "";
	Попытка
		ПутьПараметров = ПолучитьПутьПараметровЗапуска();
		Успешно = ЗагрузитьИнструментыНаСервере(ПутьПараметров);
	Исключение
		Попытка
			ЗаписатьОшибкуЗапускаНаСервере(ПутьПараметров, ОписаниеОшибки(), ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Исключение
		КонецПопытки;
	КонецПопытки;

	ЗавершитьРаботуСистемы(Ложь,, ?(Успешно, "0", "1"));
КонецПроцедуры

&НаКлиенте
Функция ПолучитьПутьПараметровЗапуска()
	Параметры = ПараметрЗапуска;
	Префикс = "DataMcpToolsLoad;Params=";
	Если Лев(Параметры, СтрДлина(Префикс)) = Префикс Тогда
		Возврат Сред(Параметры, СтрДлина(Префикс) + 1);
	КонецЕсли;
	Возврат Параметры;
КонецФункции

&НаСервереБезКонтекста
Функция ЗагрузитьИнструментыНаСервере(ПутьПараметров)
	ПутьРезультата = "";
	Попытка
		Параметры = ПрочитатьПараметрыJSON(ПутьПараметров);
		ПутьРезультата = Параметры.outputPath;
		ПутьXML = Параметры.toolsXmlPath;
		Если Не ЗначениеЗаполнено(ПутьXML) Тогда
			ВызватьИсключение "Не задан путь к XML инструментов Data MCP";
		КонецЕсли;

		Чтение = Новый ЧтениеXML;
		Чтение.ОткрытьФайл(ПутьXML);
		ЗагрузитьДанныеИзXML(Чтение);
		Чтение.Закрыть();

		ЗаписатьРезультатJSON(ПутьРезультата, "passed", "", "");
		Возврат Истина;
	Исключение
		Если ЗначениеЗаполнено(ПутьРезультата) Тогда
			ЗаписатьРезультатJSON(ПутьРезультата, "failure", ОписаниеОшибки(), ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецЕсли;
		Возврат Ложь;
	КонецПопытки;
КонецФункции

&НаСервереБезКонтекста
Функция ПрочитатьПараметрыJSON(ПутьПараметров)
	Чтение = Новый ЧтениеJSON;
	Чтение.ОткрытьФайл(ПутьПараметров, "UTF-8");
	Параметры = ПрочитатьJSON(Чтение);
	Чтение.Закрыть();
	Возврат Параметры;
КонецФункции

&НаСервереБезКонтекста
Процедура ЗаписатьОшибкуЗапускаНаСервере(ПутьПараметров, СообщениеОшибки, ДеталиОшибки)
	Если Не ЗначениеЗаполнено(ПутьПараметров) Тогда
		Возврат;
	КонецЕсли;

	Попытка
		Параметры = ПрочитатьПараметрыJSON(ПутьПараметров);
		Если ЗначениеЗаполнено(Параметры.outputPath) Тогда
			ЗаписатьРезультатJSON(Параметры.outputPath, "failure", СообщениеОшибки, ДеталиОшибки);
		КонецЕсли;
	Исключение
	КонецПопытки;
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаписатьРезультатJSON(ПутьРезультата, Статус, СообщениеОшибки, ДеталиОшибки)
	Если Не ЗначениеЗаполнено(ПутьРезультата) Тогда
		Возврат;
	КонецЕсли;

	Запись = Новый ЗаписьJSON;
	Запись.ОткрытьФайл(ПутьРезультата, "UTF-8");
	Запись.ЗаписатьНачалоОбъекта();
	ЗаписатьСвойствоJSON(Запись, "schemaVersion", 1);
	ЗаписатьСвойствоJSON(Запись, "status", Статус);
	ЗаписатьСвойствоJSON(Запись, "errorMessage", СообщениеОшибки);
	ЗаписатьСвойствоJSON(Запись, "errorDetails", ДеталиОшибки);
	Запись.ЗаписатьКонецОбъекта();
	Запись.Закрыть();
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаписатьСвойствоJSON(Запись, Имя, Значение)
	Запись.ЗаписатьИмяСвойства(Имя);
	Запись.ЗаписатьЗначение(Значение);
КонецПроцедуры

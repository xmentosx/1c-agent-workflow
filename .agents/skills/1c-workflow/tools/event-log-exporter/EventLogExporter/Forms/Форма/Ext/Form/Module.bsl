&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Успешно = Ложь;
	ПутьПараметров = "";
	Попытка
		ПутьПараметров = ПолучитьПутьПараметровЗапуска();
		Успешно = ВыгрузитьЖурналРегистрацииНаСервере(ПутьПараметров);
	Исключение
		Попытка
			ЗаписатьОшибкуЗапускаНаСервере(ПутьПараметров, ОписаниеОшибки(), ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Исключение
		КонецПопытки;
	КонецПопытки;

	ЗавершитьРаботуСистемы(Ложь,, ?(Успешно, "0", "1"));
КонецПроцедуры

&НаКлиенте
Функция ПолучитьПутьПараметровЗапуска()
	Параметры = ПараметрЗапуска;
	Префикс = "EventLogExport;Params=";
	Если Лев(Параметры, СтрДлина(Префикс)) = Префикс Тогда
		Возврат Сред(Параметры, СтрДлина(Префикс) + 1);
	КонецЕсли;
	Возврат Параметры;
КонецФункции

&НаСервереБезКонтекста
Функция ВыгрузитьЖурналРегистрацииНаСервере(ПутьПараметров)
	ПутьРезультата = "";
	Попытка
		Параметры = ПрочитатьПараметрыJSON(ПутьПараметров);
		ПутьРезультата = Параметры.outputPath;
		Уровни = УровниЖурналаРегистрацииИзПараметров(Параметры);

		Отбор = Новый Структура;
		Если ЗначениеЗаполнено(Параметры.startTime) Тогда
			Отбор.Вставить("ДатаНачала", ДатаИзISO(Параметры.startTime));
		КонецЕсли;
		Если ЗначениеЗаполнено(Параметры.endTime) Тогда
			Отбор.Вставить("ДатаОкончания", ДатаИзISO(Параметры.endTime));
		КонецЕсли;
		Если Уровни.Количество() = 1 Тогда
			Отбор.Вставить("Уровень", Уровни[0]);
		КонецЕсли;

		СобытияЖурнала = Новый ТаблицаЗначений;
		ВыгрузитьЖурналРегистрации(СобытияЖурнала, Отбор);
		ЗаписатьСобытияJSON(ПутьРезультата, СобытияЖурнала, Уровни);
		Возврат Истина;
	Исключение
		Если ЗначениеЗаполнено(ПутьРезультата) Тогда
			ЗаписатьОшибкуJSON(ПутьРезультата, ОписаниеОшибки(), ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецЕсли;
		Возврат Ложь;
	КонецПопытки;
КонецФункции

&НаСервереБезКонтекста
Функция ПрочитатьПараметрыJSON(ПутьПараметров)
	Чтение = Новый ЧтениеJSON;
	Чтение.ОткрытьФайл(ПутьПараметров, "UTF-8");
	Параметры = ПрочитатьJSON(Чтение);
	Чтение.Закрыть();
	Возврат Параметры;
КонецФункции

&НаСервереБезКонтекста
Процедура ЗаписатьОшибкуЗапускаНаСервере(ПутьПараметров, СообщениеОшибки, ДеталиОшибки)
	Если Не ЗначениеЗаполнено(ПутьПараметров) Тогда
		Возврат;
	КонецЕсли;

	Попытка
		Параметры = ПрочитатьПараметрыJSON(ПутьПараметров);
		Если ЗначениеЗаполнено(Параметры.outputPath) Тогда
			ЗаписатьОшибкуJSON(Параметры.outputPath, СообщениеОшибки, ДеталиОшибки);
		КонецЕсли;
	Исключение
	КонецПопытки;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДатаИзISO(Значение)
	Текст = Лев(Строка(Значение), 19);
	Возврат Дата(
		Число(Лев(Текст, 4)),
		Число(Сред(Текст, 6, 2)),
		Число(Сред(Текст, 9, 2)),
		Число(Сред(Текст, 12, 2)),
		Число(Сред(Текст, 15, 2)),
		Число(Сред(Текст, 18, 2)));
КонецФункции

&НаСервереБезКонтекста
Функция УровниЖурналаРегистрацииИзПараметров(Параметры)
	Уровни = Новый Массив;
	Если Не Параметры.Свойство("levels") Тогда
		Уровни.Добавить(УровеньЖурналаРегистрации.Ошибка);
		Возврат Уровни;
	КонецЕсли;

	Для Каждого Уровень Из Параметры.levels Цикл
		УровеньЖурнала = УровеньЖурналаРегистрацииПоИмени(Уровень);
		Если УровеньЖурнала <> Неопределено Тогда
			Уровни.Добавить(УровеньЖурнала);
		КонецЕсли;
	КонецЦикла;

	Если Уровни.Количество() = 0 Тогда
		Уровни.Добавить(УровеньЖурналаРегистрации.Ошибка);
	КонецЕсли;
	Возврат Уровни;
КонецФункции

&НаСервереБезКонтекста
Функция УровеньЖурналаРегистрацииПоИмени(Значение)
	Имя = НРег(СокрЛП(Строка(Значение)));
	Если Имя = "e" Или Имя = "error" Или Имя = "4" Или СтрНайти(Имя, "ошиб") > 0 Тогда
		Возврат УровеньЖурналаРегистрации.Ошибка;
	ИначеЕсли Имя = "w" Или Имя = "warning" Или Имя = "warn" Или Имя = "3" Или СтрНайти(Имя, "пред") > 0 Тогда
		Возврат УровеньЖурналаРегистрации.Предупреждение;
	ИначеЕсли Имя = "i" Или Имя = "info" Или Имя = "information" Или Имя = "2" Или СтрНайти(Имя, "инфо") > 0 Тогда
		Возврат УровеньЖурналаРегистрации.Информация;
	ИначеЕсли Имя = "n" Или Имя = "note" Или Имя = "1" Или СтрНайти(Имя, "прим") > 0 Тогда
		Возврат УровеньЖурналаРегистрации.Примечание;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

&НаСервереБезКонтекста
Функция СодержитУровеньЖурнала(Уровни, Уровень)
	Для Каждого РазрешенныйУровень Из Уровни Цикл
		Если РазрешенныйУровень = Уровень Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

&НаСервереБезКонтекста
Процедура ЗаписатьСобытияJSON(ПутьРезультата, СобытияЖурнала, Уровни)
	Запись = Новый ЗаписьJSON;
	Запись.ОткрытьФайл(ПутьРезультата, "UTF-8");
	Запись.ЗаписатьНачалоОбъекта();
	Запись.ЗаписатьИмяСвойства("schemaVersion");
	Запись.ЗаписатьЗначение(1);
	Запись.ЗаписатьИмяСвойства("status");
	Запись.ЗаписатьЗначение("passed");
	Запись.ЗаписатьИмяСвойства("events");
	Запись.ЗаписатьНачалоМассива();

	Для Каждого СтрокаСобытия Из СобытияЖурнала Цикл
		Если Уровни.Количество() > 1 И Не СодержитУровеньЖурнала(Уровни, СтрокаСобытия.Уровень) Тогда
			Продолжить;
		КонецЕсли;
		Запись.ЗаписатьНачалоОбъекта();
		ЗаписатьСвойствоJSON(Запись, "date", Строка(СтрокаСобытия.Дата));
		ЗаписатьСвойствоJSON(Запись, "level", Строка(СтрокаСобытия.Уровень));
		ЗаписатьСвойствоJSON(Запись, "event", Строка(СтрокаСобытия.Событие));
		ЗаписатьСвойствоJSON(Запись, "metadata", Строка(СтрокаСобытия.Метаданные));
		ЗаписатьСвойствоJSON(Запись, "dataPresentation", Строка(СтрокаСобытия.ПредставлениеДанных));
		ЗаписатьСвойствоJSON(Запись, "comment", Строка(СтрокаСобытия.Комментарий));
		ЗаписатьСвойствоJSON(Запись, "raw", Строка(СтрокаСобытия.Комментарий));
		Запись.ЗаписатьКонецОбъекта();
	КонецЦикла;

	Запись.ЗаписатьКонецМассива();
	Запись.ЗаписатьКонецОбъекта();
	Запись.Закрыть();
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаписатьОшибкуJSON(ПутьРезультата, СообщениеОшибки, ДеталиОшибки)
	Запись = Новый ЗаписьJSON;
	Запись.ОткрытьФайл(ПутьРезультата, "UTF-8");
	Запись.ЗаписатьНачалоОбъекта();
	Запись.ЗаписатьИмяСвойства("schemaVersion");
	Запись.ЗаписатьЗначение(1);
	Запись.ЗаписатьИмяСвойства("status");
	Запись.ЗаписатьЗначение("failure");
	ЗаписатьСвойствоJSON(Запись, "errorMessage", СообщениеОшибки);
	ЗаписатьСвойствоJSON(Запись, "errorDetails", ДеталиОшибки);
	Запись.ЗаписатьИмяСвойства("events");
	Запись.ЗаписатьНачалоМассива();
	Запись.ЗаписатьКонецМассива();
	Запись.ЗаписатьКонецОбъекта();
	Запись.Закрыть();
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаписатьСвойствоJSON(Запись, Имя, Значение)
	Запись.ЗаписатьИмяСвойства(Имя);
	Запись.ЗаписатьЗначение(Значение);
КонецПроцедуры

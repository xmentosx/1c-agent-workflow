PLATFORM_PATH=C:\Program Files\1cv8\8.3.xx.xxxx\bin\1cv8.exe
# Optional per-worktree override for automated Designer processes. Default: 10240 MB; 0 disables the guard.
# DESIGNER_MAX_WORKING_SET_MB=10240
# Optional bounded wait for automated Designer completion evidence. Default: 3600 seconds.
# DESIGNER_OPERATION_TIMEOUT_SECONDS=3600
# Optional stability interval for Designer file/log artifacts. Default: 5 seconds.
# DESIGNER_DUMP_STABILITY_SECONDS=5
INFOBASE_KIND=file
SOURCE_USES_REPOSITORY=true
SOURCE_INFOBASE_PATH=C:\1c\bases\source
SOURCE_SERVER_NAME=
SOURCE_INFOBASE_NAME=
# Optional local override. Leave commented to use .agent-1c/project.json baseConfigurationVersion.
# BASE_CONFIGURATION_VERSION=PM5
IB_USER=
# Empty value means the infobase password is not set.
IB_PASSWORD=
# Source infobase protection handling during init: manual-confirm, defer, or confirmed.
SOURCE_INFOBASE_UNSAFE_ACTION_PROTECTION_MODE=manual-confirm

# Active development branch context for ai_rules_1c IB-bound commands.
# Managed by the ITL helper when a development branch is activated.
INFOBASE_PATH=
EXPORT_PATH=
EXTENSION_NAME=
INFOBASE_PUBLISH_URL=
ITL_ACTIVE_DEV_BRANCH=
ITL_ACTIVE_DEV_BRANCH_KIND=
ITL_ACTIVE_CONTEXT_UPDATED_AT=

REPOSITORY_PATH=\\server\repo
REPOSITORY_USER=
# Empty value means the repository password is not set.
REPOSITORY_PASSWORD=

# Dependency mode used during init and automatic installs: fresh or locked.
# fresh is the default and records resolved versions/hashes into .agent-1c/dependency-lock.json.
# locked uses only pinned values from .agent-1c/dependency-lock.json.
DEPENDENCY_MODE=fresh

# Upstream ai_rules_1c modes. ITL does not reinterpret these values.
QUICKFIX_MAX_LINES=40
DEBUG_FAST_PATH=standard
VERIFICATION_DEPTH=full
UI_TESTING=manual
ORCHESTRATION=standard
SUBAGENT_MODEL_CODING=
SUBAGENT_MODEL_ANALYSIS=
SUBAGENT_MODEL_LIGHT=
# off (default), auto (long /itl commands only when SUBAGENT_MODEL_LIGHT is set), or on.
ITL_ROUTINE_MODE=off
CAVEMAN=on

# ITL executable verification policy. Valid values: auto, manual, off.
ITL_VANESSA_TESTING=auto
ITL_CHECK_EVENT_LOG=auto

# Optional GitHub API authentication for resolving latest public releases.
# GITHUB_TOKEN takes precedence over GH_TOKEN. Keep either value only in .dev.env or the process environment.
# Without a token, fresh mode uses anonymous GitHub API access and falls back to the Windows x64 baseline lock only on rate-limit 403/429.
GITHUB_TOKEN=
# GH_TOKEN=

# Verification policy for /itl-result and advanced close-dev-branch: warn or block.
# warn requires explicit unverified override when verification is missing/stale/failed.
# block forbids result export and advanced close-dev-branch until /itl-check is fresh passed.
VERIFICATION_POLICY=warn

# Machine-level port registry used to avoid collisions between ITL projects, worktrees, and terminal-server users.
# machine requires a writable directory shared by all users; use user only for user-local best-effort isolation.
ITL_PORT_REGISTRY_SCOPE=machine
ITL_PORT_REGISTRY_HOME=

# Optional override. By default development branch infobase copies are stored under .agent-1c\infobases\dev-branches and ignored by Git.
DEV_BRANCH_INFOBASE_ROOT=
# Optional parent-directory override. Worktree folders are named <project-folder>-<safe-branch>; by default they are created next to the project.
DEV_BRANCH_WORKTREE_ROOT=
# During development branch creation, ask the developer in Russian to confirm that unsafe action protection is disabled for the branch infobase user.
# Use skip only for non-interactive automation where this was handled outside the helper.
DEV_BRANCH_UNSAFE_ACTION_PROTECTION_SETUP=manual-confirm

WEB_PUBLISH_BY_DEFAULT=false
WEB_PUBLISH_AUTO=false
# Optional override. By default webinst.exe is resolved next to PLATFORM_PATH.
WEBINST_PATH=
APACHE_KIND=apache24
# Optional overrides for an existing web publication contour prepared outside ITL workflow.
APACHE_HTTPD_CONF_PATH=
WEB_PUBLICATION_ROOT=
WEB_PUBLICATION_URL_BASE=

# Vanessa Automation is installed locally during init and is required for executable branch tests.
VANESSA_AUTOMATION_ROOT=.agent-1c/tools/vanessa-automation
# Maintainer-only pre-publication qualification override. It must point to the
# exact workflow-pinned ZIP; the helper always verifies the canonical SHA-256.
# ITL_VANESSA_AUTOMATION_SOURCE_BUILD_ARCHIVE=
VANESSA_AUTOMATION_EPF=
VANESSA_AUTOMATION_VERSION=
VANESSA_FEATURES_PATH=tests/features
VANESSA_REPORTS_PATH=build/test-results/vanessa

# Vanessa verify runs through TESTMANAGER -> TESTCLIENT. The helper assigns a branch-local TestClient port.
VANESSA_TEST_PORT_RANGE=48051..48150
VANESSA_TEST_PORT=
# Default warn mode prints foreign branch Vanessa process diagnostics but does not wait.
# Set to wait only when a local machine needs conservative serialized UI-test runs.
VANESSA_TEST_FOREIGN_WAIT_MODE=warn
# Quiet/timeout values are used only when VANESSA_TEST_FOREIGN_WAIT_MODE=wait.
VANESSA_TEST_FOREIGN_QUIET_SECONDS=60
VANESSA_TEST_FOREIGN_WAIT_TIMEOUT_SECONDS=600
VANESSA_TEST_TIMEOUT_SECONDS=1800
VANESSA_TEST_CLIENT_STARTUP_TIMEOUT_SECONDS=300
VANESSA_TEST_WINDOW_SEARCH_TIMEOUT_SECONDS=60
# Shared TestClient capacity used by verification and Vanessa UI MCP preflight.
# Set this to the actual number of concurrently usable developer TestClient licenses.
VANESSA_TESTCLIENT_LICENSE_CAPACITY=2
VANESSA_EVENT_LOG_LEVELS=Error
VANESSA_EVENT_LOG_CLOCK_SKEW_SECONDS=5
VANESSA_EVENT_LOG_READER=auto

# Vanessa UI MCP is branch-local runtime tooling and starts on demand. It is distinct from Vanessa Automation verification.
VANESSA_MCP_AUTO_START=false
VANESSA_MCP_INSTALL_ROOT=.agent-1c/tools/vanessa-mcp
VANESSA_MCP_CLIENT_CFE_PATH=
VANESSA_MCP_CLIENT_CFE_VERSION=
VANESSA_MCP_CLIENT_CFE_SHA256=
VANESSA_MCP_VA_EXTENSION_CFE_PATH=
VANESSA_MCP_VA_EXTENSION_CFE_VERSION=
VANESSA_MCP_VA_EXTENSION_CFE_SHA256=
VANESSA_MCP_PORT_RANGE=9874..9973
VANESSA_MCP_TESTCLIENT_PORT_RANGE=48151..48250
VANESSA_MCP_PORT=
VANESSA_MCP_URL=

# ROCTUP MCP Toolkit is the preferred branch-local data MCP. It does not require web publication and starts on demand.
ROCTUP_MCP_ENABLED=true
ROCTUP_MCP_AUTO_START=false
ROCTUP_MCP_REQUIRED=false
ROCTUP_MCP_INSTALL_ROOT=.agent-1c/tools/roctup-mcp-toolkit
ROCTUP_MCP_PORT_RANGE=6003..6102
ROCTUP_MCP_TOOLKIT_EPF=
ROCTUP_MCP_VERSION=
ROCTUP_MCP_SHA256=
ROCTUP_MCP_PORT=
ROCTUP_MCP_URL=
ROCTUP_MCP_HEALTH_URL=

# vibecoding1c MCP setup runs during init by default; it can still be rerun through a normal agent request or helper action. Remote LAN endpoints are the default.
# Keep license keys only in the private distribution or local vibecoding1c MCP config.
VIBECODING1C_MCP_DISTRIBUTION_REPO=http://gitlabserv01.itland.local/root/MCP-vibecoding1c.git
# Optional path override for a manually prepared distribution checkout.
VIBECODING1C_MCP_DISTRIBUTION_PATH=
# Remote vibecoding1c MCP registry. It contains only LAN HTTP endpoints and freshness metadata, no secrets.
VIBECODING1C_MCP_REGISTRY_REPO=http://gitlabserv01.itland.local/root/MCP-vibecoding1c-registry.git
# Optional path override for a manually prepared registry checkout.
VIBECODING1C_MCP_REGISTRY_PATH=
PATH_METADATA=
PATH_CODE=
PATH_BASES=
USE_GPU=false

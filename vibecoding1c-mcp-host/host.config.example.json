  "embedding": {
    "model": "intfloat/multilingual-e5-base"
  },
  "codeMetadataSearchServer": {
    "resetDatabase": false,
    "reindexIntervalHours": null
  },
  "graphMetadataSearchServer": {
    "resetDatabase": false,
    "reindexIntervalHours": null,
    "autoUpdateOnStartup": true
  },
  "bookStackProductDocsServer": {
    "baseUrl": "http://bookstack.itland.local",
    "cachePath": "D:/ITL/MCP/vibecoding1c/bookstack-product-docs",
    "resetDatabase": false,
    "reindexIntervalHours": 24,
    "indexOnStartup": true,
    "maxIndexPages": null,
    "semanticMinScore": 0.82,
    "timeoutSeconds": 20
  },
  "mantisTicketServer": {
    "baseUrl": "http://mantis.itland.local",
    "attachmentCachePath": "D:/ITL/MCP/vibecoding1c/mantis-ticket/attachments",
    "timeoutSeconds": 20,
    "maxAttachmentBytes": 26214400,
    "maxInlineTextChars": 16000,
    "ocr": {
      "enabled": true,
      "languages": [ "rus", "eng" ]
    }
  },
  "helpSearchServer": {
    "platformVersion": "8.3.24.1548",

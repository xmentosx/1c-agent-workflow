  },
  "sslSearchServer": {
    "bspVersion": "3.1.10"
  },
  "portRanges": {
    "globalStart": 18000,
    "projectStart": 18100
  },
  "toolsListProxy": {
    "enabled": true,
    "serverIds": [ "docs", "templates", "syntax", "codechecker", "ssl", "bookstack", "mantis", "code", "graph" ],
    "portOffset": 4000,
    "image": "itl/mcp-tools-list-proxy:local"
  },
  "enabledServers": {
    "global": [ "docs", "templates", "syntax", "codechecker", "ssl", "bookstack", "mantis" ],
    "project": [ "code", "graph" ]
  },
  "configurations": [
